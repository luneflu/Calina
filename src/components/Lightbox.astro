<!-- LIGHTBOX OVERLAY -->
<div id="lightbox"
    class="fixed inset-0 w-full h-full bg-[rgba(0,0,0,0.92)] hidden justify-center items-center z-[9999] cursor-pointer p-8"
>
    <button
        id="lightbox-close"
        class="absolute top-6 right-8 text-white text-[2.5rem] cursor-pointer transition-transform duration-200 bg-transparent border-none z-[10000] hover:scale-110 hover:text-yellow-400"
    >&times;</button>
    <img id="lightboxImg"
        class="max-w-[90vw] max-h-[90vh] object-contain border-2 border-white/10 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.8)]"
        src="" alt="Galeri Proyek" />
    <div id="lightboxCaption"
        class="absolute bottom-8 inset-x-0 text-center text-[#ccc] font-sans text-[0.9rem] tracking-[0.5px] px-4">
    </div>
</div>

<script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;
    const caption = document.getElementById('lightboxCaption');
    const closeBtn = document.getElementById('lightbox-close');

    function open(src: string, title: string, subtitle?: string) {
        if (!lightbox || !lightboxImg || !caption) return;
        lightboxImg.src = src;
        lightboxImg.alt = title || 'Galeri Proyek';
        caption.textContent = subtitle ? `${subtitle} — ${title}` : title;
        
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden'; // disable scroll
    }

    function close() {
        if (!lightbox) return;
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = ''; // enable scroll
    }

    // Attach click listeners to all triggers
    document.querySelectorAll('.lightbox-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
            const el = trigger as HTMLElement;
            const src = el.getAttribute('data-lightbox-src');
            const title = el.getAttribute('data-lightbox-title') || '';
            const subtitle = el.getAttribute('data-lightbox-subtitle') || '';
            if (src) {
                open(src, title, subtitle);
            }
        });
    });

    // Close on clicking backdrop
    lightbox?.addEventListener('click', (e) => {
        // Only close if clicking the backdrop container itself, not its children (image, caption)
        if (e.target === lightbox) {
            close();
        }
    });

    // Close on clicking the close button
    closeBtn?.addEventListener('click', (e) => {
        close();
        e.stopPropagation();
    });

    // Close on pressing Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            close();
        }
    });
</script>
