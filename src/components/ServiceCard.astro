---
interface Props {
	title: string;
	description: string;
	points?: string[];
	link?: string;
	src?: string;
}

const { title, description, points = [], link = "#", src, ...rest } = Astro.props;
---

<div class="service-card bg-neutral-900 border border-white/10 flex flex-col justify-between group m-4 cursor-pointer lightbox-trigger" data-lightbox-src={src} data-lightbox-title={title} data-lightbox-subtitle="" {...rest}>
    <div class="p-6 flex-1 flex flex-col justify-between">
        <div>
            <h3 class="text-sm font-bold mb-3 uppercase tracking-widest text-yellow-400">{title}</h3>
            <p class="text-neutral-400 text-xs font-sans font-light leading-relaxed mb-4">
                {description}
            </p>
            {points.length > 0 && (
                <ul class="text-neutral-500 text-xs font-sans list-none space-y-2 mb-4">
                    {points.map((point) => (
                        <li class="flex items-start gap-2">
                            <span class="text-yellow-600 mt-0.5 shrink-0">›</span>
                            <span>{point}</span>
                        </li>
                    ))}
                </ul>
            )}
        </div>
        <a href={link} class="arrow-link text-yellow-600 font-bold font-mono text-sm" onclick="event.preventDefault();">
            →
        </a>
    </div>
    <div class="service-img-wrap h-[180px] w-full">
        {src && (
            <img src={src} alt={title} class="w-full h-full object-cover" loading="lazy" />
        )}
    </div>
</div>
