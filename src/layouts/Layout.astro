---
import '@fortawesome/fontawesome-svg-core/styles.css';
import 'aos/dist/aos.css';
import '../styles/global.css';
import { config } from '@fortawesome/fontawesome-svg-core';
import Lightbox from '../components/Lightbox.astro';
import Font from 'astro/components/Font.astro';

// Prevent Font Awesome from dynamically adding its css since we did it manually above
config.autoAddCss = false;

interface Props {
	title?: string;
}

const { title = "PT Cahaya Lintang Abadi" } = Astro.props;
---

<!doctype html>
<html lang="id" class="overflow-x-hidden scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
		<meta name="description"
			content="PT Cahaya Lintang Abadi - Penyedia jasa konstruksi, pemeliharaan jalan tol, infrastruktur, kebersihan, dan tenaga kerja handal. Partner In Excellence untuk proyek infrastruktur nasional.">
		<meta name="author" content="PT Cahaya Lintang Abadi">
		<meta name="keywords"
			content="konstruksi jalan tol, pemeliharaan infrastruktur, jasa kebersihan, penyedia tenaga kerja, pemeliharaan jalan tol, perawatan jalan tol, jasa konstruksi, infrastruktur nasional, BUMN, kontraktor, perawatan jalan tol manado, pembersihan rambu lalu lintas">
		<meta property="og:site_name" content="PT Cahaya Lintang Abadi">
		<meta property="og:site" content="https://www.cahayalintangabadi.com">
		<meta property="og:title"
			content="PT Cahaya Lintang Abadi - Partner In Excellence | Konstruksi & Pemeliharaan Infrastruktur">
		<meta property="og:description"
			content="Layanan konstruksi, pemeliharaan jalan tol, infrastruktur, kebersihan, dan penyediaan tenaga kerja handal berskala nasional. Partner terpercaya untuk proyek BUMN dan swasta.">
		<meta property="og:image" content="https://www.cahayalintangabadi.com/images/logo-cla.webp">
		<meta property="og:url" content="https://www.cahayalintangabadi.com">
		<meta property="og:type" content="company">
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		
		<Font cssVariable="--font-sans" />
		<Font cssVariable="--font-syne" />
		<Font cssVariable="--font-mono" />
	</head>

	<body class="flex flex-col min-h-screen overflow-x-hidden">
		<slot />

		<Lightbox />

		<!-- AOS Animation Library -->
		<script>
			import AOS from 'aos';
			
			// Initialize AOS when the page loads
			document.addEventListener('DOMContentLoaded', () => {
				AOS.init({
					duration: 800,
					once: true,
					offset: 100,
					easing: 'ease-out-cubic'
				});
			});
		</script>
	</body>
</html>
